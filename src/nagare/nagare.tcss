Screen {
    layout: horizontal;
}

#left-pane {
    width: 30%;
    border: solid $primary;
}

#left-pane.inactive-pane {
    border: solid $surface;
}

SessionList {
    height: 1fr;
}

SessionDetail {
    height: auto;
}

TerminalView {
    width: 70%;
}

FooterBar {
    dock: bottom;
    width: 100%;
}
